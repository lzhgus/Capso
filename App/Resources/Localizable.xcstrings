    "Five minutes to set up." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "設定は 5 分で完了。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "5분이면 설정 완료." } },
