    "Cleaning up…" : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "クリーンアップ中…" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "정리 중…" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在清理…" } }
      }
    },
    "Step 1 — Introduction" : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ステップ 1 — はじめに" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "1단계 — 소개" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "第 1 步 — 简介" } }
      }
    },
    "Capso uploads to **your own cloud storage** — never our servers. You bring the bucket, you own the files, you keep the bill. We just hand you the share link." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Capso はファイルを**あなた自身のクラウドストレージ**にアップロードします — 当社のサーバーには送りません。バケットはあなたのもの、ファイルもあなたのもの、料金もあなた負担。私たちは共有リンクをお渡しするだけです。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Capso는 파일을 **내 클라우드 스토리지**에 업로드합니다 — 저희 서버에는 절대 저장되지 않습니다. 버킷은 내 것, 파일도 내 것, 비용도 내가 냅니다. 저희는 공유 링크만 전달합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Capso 将文件上传到**您自己的云存储** — 从不经过我们的服务器。存储桶是您的，文件是您的，费用也由您支付。我们只是把分享链接交到您手中。" } }
      }
    },
    "Yours forever." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "永遠にあなたのもの。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "영원히 내 것." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "永久属于您。" } }
      }
    },
    "Files live in your account. Cancel Capso, keep your screenshots." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ファイルはあなたのアカウントに保存されます。Capso を解約しても、スクリーンショットはそのまま残ります。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "파일은 내 계정에 저장됩니다. Capso를 취소해도 스크린샷은 그대로 유지됩니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "文件保存在您的账户中。取消 Capso 订阅，截图依然保留。" } }
      }
    },
    "Free tier friendly." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "無料プランで十分。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "무료 플랜으로 충분." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "免费套餐即可使用。" } }
      }
    },
    "Cloudflare R2 includes 10 GB and zero egress fees." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Cloudflare R2 は 10 GB の無料ストレージと 0 円の下り転送費を提供します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Cloudflare R2는 10GB 무료 저장 공간과 제로 이그레스 요금을 제공합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Cloudflare R2 提供 10 GB 免费存储，且无出流量费用。" } }
      }
